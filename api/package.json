{
  "name": "basis-transport-be",
  "version": "1.0.0",
  "description": "Backend of Basis Transport, a bus tracking and fleet management application",
  "main": "src/server.ts",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node ./src/server.ts",
    "start": "npm i && tsc && node ./dist/server.js",
    "seed:permissions": "ts-node ./src/seeds/permissions.seed.ts",
    "seed:roles": "ts-node ./src/seeds/roles.seed.ts",
    "seed:super-admin": "ts-node ./src/seeds/super-admin.seed.ts",
    "seed": "npm run seed:permissions && npm run seed:roles && npm run seed:super-admin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basis-ltd/basis-transport-be.git"
  },
  "keywords": [
    "bus",
    "tracking"
  ],
  "author": "Nishimwe Prince",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/basis-ltd/basis-transport-be/issues"
  },
  "homepage": "https://github.com/basis-ltd/basis-transport-be#readme",
  "dependencies": {
    "@react-email/components": "^1.0.11",
    "@react-email/render": "^2.0.5",
    "bcrypt": "^5.1.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.41",
    "pg": "^8.15.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.10.0",
    "typeorm": "^0.3.22",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "morgan": "^1.10.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
